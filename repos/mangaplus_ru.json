    "author": {
        "name": "AniLabX Team",
        "email": "anilabx.supp@gmail.com"
    },
    "manga_search_complete": {
        "search_link": "$scheme$//$hostname$/search?q=$query$&page=$page$",
        "query_type": "GET",
        "add_manga": {
            "next": "card card-gallery",
            "link": {
                "token1": "href=\"",
                "token2": "\""
            },
            "title": {
                "token1": "class=\"title\">",
                "token2": "</",
                "replace": {
                    "match": "<br />",
                    "text": " / "
                }
            },
            "cover": {
                "token1": "data-src=\"",
                "token2": "\"",
                "replace": {
                    "match": "^//",
                    "text": "https://"
                }
            }
        }
    },
    "manga_list_complete": {
        "iterator": [
            {
                "category": {
                    "tag": "main",
                    "name": "Последние"
                },
                "base_url": "$scheme$//$hostname$/browse/newest?page=",
                "append_nums": {
                    "from": 0,
                    "to": 2300,
                    "step": 1
                }
            }
        ],
        "add_manga": {
            "next": "card card-gallery",
            "link": {
                "token1": "href=\"",
                "token2": "\""
            },
            "title": {
                "token1": "class=\"title\">",
                "token2": "</",
                "replace": {
                    "match": "<br />",
                    "text": " / "
                }
            },
            "cover": {
                "token1": "data-src=\"",
                "token2": "\"",
                "replace": {
                    "match": "^//",
                    "text": "https://"
                }
            }
        }
    },
    "manga_complete": {
        "title": {
            "skip": "<h1><a",
            "token1": "\">",
            "token2": "</"
        },
        "cover": {
            "skip": "avif 1x",
            "token1": "srcset=\"",
            "token2": " ",
            "prefix": "https:"
        },
        "add_artists": {
            "start": "comma-list",
            "next": "/artist/",
            "token1": "\">",
            "token2": "</a",
            "end": "</ul>"
        },
        "add_circles": {
            "start": ">Group<",
            "next": "/group/",
            "token1": "\">",
            "token2": "</a",
            "end": "</ul>"
        },
        "add_parodies": {
            "start": ">Series<",
            "next": "/series/",
            "token1": "\">",
            "token2": "</a",
            "end": "</ul>"
        },
        "add_languages": {
            "start": ">Language<",
            "next": "href=",
            "token1": "\">",
            "token2": "</a",
            "end": "</td>"
        },
        "add_characters": {
            "start": ">Characters<",
            "next": "/character/",
            "token1": "\">",
            "token2": "</a",
            "end": "</ul>"
        },
        "add_genres": {
            "start": "<td>Tags</td>",
            "next": "/tag/",
            "token1": "\">",
            "token2": "</a",
            "end": "</ul>"
        },
        "status": {
            "default": "single"
        },
        "censorship": {
            "uncensored": ">Uncensored<",
            "decensored": "(Decensored)",
            "censored": ">full censorship<"
        },
        "color": {
            "full_color": ">Full Color<"
        },
        "content_type": {
            "manga": "manga",
            "default": "doujinshi"
        },
        "is_adult": "hitomi",
        "add_chapter": {
            "start": "ztable-collectionz",
            "next": "<td>#",
            "link": {
                "token1": "href=\"",
                "token2": "\"",
                "replace": {
                    "match": "gallery/(\\d+)/",
                    "text": "read/$1/01/"
                }
            },
            "title": "Gallery"
        }
    },
