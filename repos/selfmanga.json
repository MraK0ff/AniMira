            "default": "ongoing"
        },
        "status": {
            "complete": "data-production-status=\"FINISHED\"",
            "ongoing": "data-production-status=\"PROGRESS\"",
            "on_hold": "data-production-status=\"POSTPONED\"",
            "single": "<b>Сингл</b>",
            "licensed": "Главы удалены",
            "unknown": "нет ни одной главы"
        },
        "read_dir": {
            "right_to_left": "tag/noyaoi",
            "left_to_right": "category/manhwa"
        },
        "cover": {
            "after": "main-carousel__swiper",
            "token1": "src=\"",
            "token2": "\""
        },
        "add_artists": {
            "start": "<span>Художник</span>",
            "next": "entity-card-tile__title",
            "token1": "entity-card-tile__title\">",
            "token2": "</",
