            "token2": "</",
            "end": "</div>"
        },
        "add_genres": {
            "start": "class=\"cr-tags\"",
            "token1": "<span>",
            "token2": "</",
            "end": "cr-tags__toggle"
        },
        "add_tags": {
            "start": ">Теги:",
            "token1": "element-link\" hideLink=\"\">",
            "token2": "<",
            "end": "</p>"
        },
        "content_type": {
            "manhwa": "manhwa\">Манхва",
            "manhua": "manhua\">Маньхуа",
            "default": "manga"
        },
        "is_mature": ">NC-17<",
        "is_adult": ">R<",
        "add_chapter": {
            "start": "<table class=\"table table-hover\"",
            "next": "item-status",
            "link": {
                "token1": "<a href=\"",
                "token2": "\"",
                "replace": {
                    "prefix": "$scheme$//$hostname$",
                    "sufix": "?mtr=1"
                }
            },
            "title": {
                "after": "<a href=\"",
                "token1": ">",
                "token2": "<",
                "replace": [
                    {
                        "match": "(.*)\n          \n          ",
                        "text": ""
                    },
                    {
                        "match": "^(\\d+) - (\\d+.\\d+)",
                        "text": "Том $1 - Глава $2:"
                    },
                    {
                        "match": "^(\\d+) - (\\d+)",
                        "text": "Том $1 - Глава $2:"
                    },
                    {
                        "match": ":$",
                        "text": ""
                    }
                ]
            },
            "date": {
                "after": "cell date",
                "token1": "data-date=\"",
                "token2": "\""
            },
            "uniq": {
                "after": "href=\"",
                "token1": "/vol",
                "token2": "\"",
                "replace": {
                    "match": "\\?.*",
                    "text": ""
                }
            },
            "end": "</table>"
        }
    },
