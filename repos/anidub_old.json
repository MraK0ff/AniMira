            ]
        },
        "alt_title": {
            "skip": "class=\"fheader",
            "token1": "</div>",
            "token2": "<div",
            "replace": [
                {
                    "match": "<h1>.*",
                    "text": ""
                },
                {
                    "match": ".*<h3>",
                    "text": ""
                },
                {
                    "match": "</h3>.*",
                    "text": ""
                },
                {
                    "match": "<h4>.*",
                    "text": ""
                },
                {
                    "match": " / .*",
                    "text": ""
                },
                {
                    "match": "\\[.*\\]",
                    "text": ""
                },
                {
                    "trim": true
                }
            ]
        },
        "uniq": {
            "after": "<h2>",
            "token1": "/ ",
            "token2": "</",
            "replace": [
                {
                    "match": "\\[.*\\]",
                    "text": ""
                },
                {
                    "trim": true
                }
            ]
        },
        "cover": {
            "after": "fposter",
            "token1": "src=\"",
            "token2": "\"",
            "replace": [
                {
                    "match": "^/",
                    "text": "$scheme$//$hostname$/"
