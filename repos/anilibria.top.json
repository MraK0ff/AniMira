    "anime_search_complete": {
        "search_link": "$scheme$//$hostname$/anime/catalog?search=$query$",
        "query_type": "GET",
        "add_anime": {
            "start": "window.__NUXT__",
            "next": "\"id\":",
            "link": {
                "skip": "\"alias\":\"",
                "token1": "\"alias\":\"",
                "token2": "\"",
                "replace": {
                    "prefix": "$scheme$//$hostname$/anime/releases/release/",
                    "unescape_unicode": true
                }
            },
            "title": {
                "skip": "\"main\":\"",
                "token1": "\"main\":\"",
                "token2": "\"",
                "replace": {
                    "unescape_unicode": true
                }
            },
            "additional_title": {
                "skip": "\"english\":\"",
                "token1": "\"english\":\"",
                "token2": "\"",
                "replace": {
                    "unescape_unicode": true
                }
            },
            "cover": {
                "skip": "\"poster\":",
                "token1": "\"src\":\"",
                "token2": "\"",
                "replace": {
                    "unescape_unicode": true
                }
            },
            "end": "</script>"
        }
    },
    "anime_list_complete": {
        "iterator": {
            "category": {
                "tag": "main",
                "name": "Каталог"
            },
            "base_url": "$scheme$//$hostname$/anime/catalog?page=$page$",
            "append_nums": {
                "from": 1,
                "to": 50,
                "step": 1
            }
        },
        "add_anime": {
            "start": "window.__NUXT__",
            "next": "\"id\":",
            "link": {
                "skip": "\"alias\":\"",
                "token1": "\"alias\":\"",
                "token2": "\"",
                "replace": {
                    "prefix": "$scheme$//$hostname$/anime/releases/release/",
                    "unescape_unicode": true
                }
            },
            "title": {
                "skip": "\"main\":\"",
                "token1": "\"main\":\"",
                "token2": "\"",
                "replace": {
                    "unescape_unicode": true
                }
            },
            "additional_title": {
                "skip": "\"english\":\"",
                "token1": "\"english\":\"",
                "token2": "\"",
                "replace": {
                    "unescape_unicode": true
                }
            },
            "cover": {
                "skip": "\"poster\":",
                "token1": "\"src\":\"",
                "token2": "\"",
                "replace": {
                    "unescape_unicode": true
                }
            },
            "episodes_aired": {
                "skip": "\"episodesTotal\":",
                "token1": "\"episodesTotal\":",
                "token2": ",",
                "replace": {
                    "unescape_unicode": true
                }
            },
            "end": "</script>"
        }
    },
    "anime_complete": {
        "title": {
            "start": "window.__NUXT__",
            "token1": "\"main\":\"",
            "token2": "\"",
            "replace": {
                "unescape_unicode": true
            }
        },
        "additional_title": {
            "start": "window.__NUXT__",
            "skip": "\"english\":\"",
            "token1": "\"english\":\"",
            "token2": "\"",
            "replace": {
                "unescape_unicode": true
            }
        },
        "uniq": {
            "start": "window.__NUXT__",
            "skip": "\"alias\":\"",
            "token1": "\"alias\":\"",
            "token2": "\"",
            "replace": {
                "unescape_unicode": true
            }
        },
        "cover": {
            "start": "window.__NUXT__",
            "skip": "\"poster\":",
            "token1": "\"src\":\"",
            "token2": "\"",
            "replace": {
                "unescape_unicode": true
            }
        },
        "production_year": {
            "start": "window.__NUXT__",
            "skip": "\"year\":",
            "token1": "\"year\":",
            "token2": ",",
            "replace": {
                "unescape_unicode": true
            }
        },
        "episodes": {
            "start": "window.__NUXT__",
            "skip": "\"episodesTotal\":",
            "token1": "\"episodesTotal\":",
            "token2": ",",
            "replace": {
                "unescape_unicode": true
            }
        },
        "summary": {
            "start": "window.__NUXT__",
            "skip": "\"description\":\"",
            "token1": "\"description\":\"",
            "token2": "\"",
            "replace": {
                "unescape_unicode": true,
                "match": "\\\\r\\\\n",
                "text": " "
            }
        },
        "status": {
            "ongoing": "\"isOngoing\":true",
            "default": "complete"
        },
        "content_type": {
            "anime": "TV",
            "default": "anime"
        },
        "add_genre": {
            "start": "window.__NUXT__",
            "skip": "\"genres\":[",
            "token1": "\"name\":\"",
            "token2": "\"",
            "split": ",",
            "end": "]"
        }
    },
    "seasons_complete": {
        "get_translations": true
    },
    "translations_complete": {
        "get_episodes": true
    },
    "episodes_complete": {
        "add_episode": [
            {
                "start": "window.__NUXT__",
                "next": "\"episodes\":[",
                "link": {
                    "skip": "\"hls720\":\"",
                    "token1": "\"hls720\":\"",
                    "token2": "\"",
                    "replace": {
                        "unescape_unicode": true
                    }
                },
                "title": {
                    "skip": "\"name\":\"",
                    "token1": "\"name\":\"",
                    "token2": "\"",
                    "replace": {
                        "unescape_unicode": true,
                        "match": "^$",
                        "text": "Серия"
                    }
                },
                "uniq": {
                    "skip": "\"id\":",
                    "token1": "\"id\":",
                    "token2": ",",
