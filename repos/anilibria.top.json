                    },
                    {
                        "name": "По году (старые)",
                        "value": "YEAR_ASC"
                    }
                ]
            },
            "1_genres": {
                "name": "Жанры",
                "choice_mode": "multiple",
                "filter_type": "get_query",
                "query_name": "f[genres]",
