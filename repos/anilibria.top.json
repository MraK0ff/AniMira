{
    "id": 20001,
    "version": 2,
    "title": "AniLibria (new site)",
    "host": "https://anilibria.top",
    "public_link": "https://anilibria.top",
    "api": "anilibria_top",
    "api_endpoint": "https://anilibria.top/api/v1/",
    "hash_tag": "anilibria",
    "folder": "anilibria_top",
    "name": "anilibria_top",
    "language": "ru",
    "content_type": "anime",
    "episodes_order": true,
    "icon_link": "https://cdn.anilibria.top/static/favicon-96x96.png",
    "self_link": "https://api.anilabx.xyz/v3/parser/get?type=anime&parser=anilibria_top",
    "author": {
        "name": "AniLabX Team",
        "email": "anilabx.supp@gmail.com"
    },
    "custom_settings": {
        "is_allow_host_mirroring": true,
        "mirrors": [
            {
                "name": "Основное",
                "url": "https://anilibria.top"
            }
        ]
    },
    "anime_list_filters_complete": {
