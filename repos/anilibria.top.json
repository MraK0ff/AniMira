    "anime_search_complete": {
        "search_link": "$api_endpoint$app/search/releases?search=$query$&limit=20",
        "query_type": "GET",
        "json_content": true,
        "add_anime": {
            "iterator": {
                "path": "data",
                "link": {
                    "from": "alias",
                    "replace": {
                        "prefix": "$scheme$//$hostname$/anime/releases/release/"
                    }
                },
                "title": {
                    "from": "name.main"
                },
                "additional_title": {
                    "from": "name.english"
                },
                "cover": {
                    "from": "poster.src"
                },
                "uniq": {
                    "from": "alias"
                }
            }
        }
    },
    "anime_list_complete": {
        "iterator": {
            "category": {
                "tag": "main",
                "name": "Каталог"
            },
            "base_url": "$api_endpoint$anime/catalog/releases?page=$page$&limit=20",
            "append_nums": {
                "from": 1,
                "to": 50,
                "step": 1
            }
        },
        "json_content": true,
        "add_anime": {
            "iterator": {
                "path": "data",
                "link": {
                    "from": "alias",
                    "replace": {
                        "prefix": "$scheme$//$hostname$/anime/releases/release/"
                    }
                },
                "title": {
                    "from": "name.main"
                },
                "additional_title": {
                    "from": "name.english"
                },
                "cover": {
                    "from": "poster.src"
                },
                "episodes_aired": {
                    "from": "episodes_total"
                },
                "uniq": {
                    "from": "alias"
                }
            }
        }
    },
    "anime_complete": {
        "link": "$api_endpoint$anime/releases/$alias$?include=episodes",
        "json_content": true,
        "title": {
            "from": "data.name.main"
        },
        "additional_title": {
            "from": "data.name.english"
        },
        "uniq": {
            "from": "data.alias"
        },
        "cover": {
            "from": "data.poster.src"
        },
        "production_year": {
            "from": "data.year"
        },
        "episodes": {
            "from": "data.episodes_total"
        },
        "summary": {
            "from": "data.description"
        },
        "status": {
            "from": "data.is_ongoing",
            "mapping": {
                "true": "ongoing",
                "false": "complete"
            }
        },
        "content_type": {
            "default": "anime"
        },
        "add_genre": {
            "from": "data.genres",
            "field": "name"
        }
    },
    "seasons_complete": {
        "get_translations": true
    },
    "translations_complete": {
        "get_episodes": true
    },
    "episodes_complete": {
        "json_content": true,
        "add_episode": [
            {
                "iterator": {
                    "path": "data.episodes",
                    "title": {
                        "from": "name"
                    },
                    "link": {
                        "from": "hls_720"
                    },
                    "uniq": {
                        "from": "id"
                    }
                },
                "direct_links": true
            },
            {
                "may_be_null": true,
                "iterator": {
                    "path": "data.episodes",
                    "title": {
                        "from": "name",
                        "replace": {
                            "suffix": " (1080p)"
                        }
                    },
                    "link": {
                        "from": "hls_1080"
                    },
                    "uniq": {
                        "from": "id",
                        "replace": {
                            "suffix": "_1080"
                        }
                    }
                },
                "direct_links": true
            },
            {
                "may_be_null": true,
                "iterator": {
                    "path": "data.episodes",
                    "title": {
                        "from": "name",
                        "replace": {
                            "suffix": " (480p)"
                        }
                    },
                    "link": {
                        "from": "hls_480"
                    },
                    "uniq": {
                        "from": "id",
                        "replace": {
                            "suffix": "_480"
                        }
                    }
                },
                "direct_links": true
            }
        ]
    },
    "torrents_complete": {},
    "episode_complete": {
        "headers": {
            "Referer": "$scheme$//$hostname$"
        }
    },
    "test": [
        {
            "proc": "anime_list_complete",
            "testpages": 2,
            "assert": {
                "animes": [
                    {
                        "title": "@^(\\w+)",
                        "link": "@https://anilibria.top/anime/releases/release/",
                        "uniq": "@^(\\w+)"
                    }
                ],
                "animes_count": ">=10"
            }
        },
        {
            "proc": "anime_complete",
            "link": "https://anilibria.top/anime/releases/release/needy-girl-overdose",
            "assert": {
                "title": "Зависимая девушка: Передозировка",
                "additional_title": "Needy Girl Overdose",
                "uniq": "needy-girl-overdose",
                "cover": "@https://cdn.anilibria.top/",
                "year": "2026",
                "content_type": "anime",
                "status": "ongoing"
            }
        }
    ]
}
