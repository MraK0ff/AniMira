    "anime_complete": {
        "title": {
            "skip": "og:title",
            "token1": "content='",
            "token2": "'",
            "replace": {
                "match": ".* / ",
                "text": ""
            }
        },
        "additional_title": {
            "skip": "og:title",
            "token1": "content='",
            "token2": "'",
            "replace": {
                "match": " / .*",
                "text": ""
            }
        },
        "uniq": {
            "skip": "og:title",
            "token1": "content='",
            "token2": "'",
            "replace": {
                "match": ".* / ",
                "text": ""
            }
        },
        "cover": {
            "after": "detail_torrent_pic",
            "token1": "src=\"",
            "token2": "\""
        },
        "add_dubber": {
            "after": ">Озвучка<",
            "token1": ":",
            "token2": "<br",
            "split": ","
        },
        "production_year": {
            "skip": ">Год:<",
            "token1": ">",
            "token2": "<"
        },
        "ep_length": {
            "skip": ">Тип:<",
            "token1": ">",
            "token2": "<",
            "replace": {
                "match": ".*,",
                "text": ""
            }
        },
        "episodes": {
            "skip": ">Тип:<",
            "token1": ">",
            "token2": "<",
            "replace": {
                "match": "\\((.*?)\\)",
                "match_number": "1",
                "group": "1"
            }
        },
        "summary": {
            "skip": "og:description",
            "token1": "content='",
            "token2": "'"
        },
        "is_have_subs": ">Субтитры",
        "status": {
            "ongoing": "Новая серия кажд",
            "default": "complete"
        },
        "content_type": {
            "anime": "Ani",
            "default": "anime"
        },
        "add_genre": {
            "after": ">Жанры:<",
            "token1": "b>",
            "token2": "<",
            "split": ","
        },
        "related": {
            "after": ">Порядок просмотра:<",
            "token1": "<br>",
            "token2": "</div>",
            "!replace": {
                "match": "href=\"/",
                "text": "href=\"$scheme$//$hostname$/"
            }
        }
    },
    "seasons_complete": {
        "get_translations": true
    },
    "translations_complete": {
        "get_episodes": true
    },
    "episodes_complete": {
        "add_episode": [
            {
                "direct_links": true,
                "start": "new Playerjs",
                "next": "'title'",
                "link": {
                    "token1": "'file':'",
                    "token2": ",",
                    "replace": {
                        "match": "\\[.*\\]",
                        "text": "https:"
                    }
                },
                "title": {
                    "token1": "'title':'",
                    "token2": "'"
                },
                "uniq": {
                    "token1": "'title':'",
                    "token2": "'"
                }
            },
            {
                "may_be_null": true,
                "episodes_from_page": {
                    "after": "id=\"moonPlayer\"",
                    "token1": "src=\"",
                    "token2": "\"",
                    "replace": {
                        "match": "^//",
                        "text": "http://"
                    }
                },
                "start": "class=\"serial-series-box",
                "next": "<option",
                "link": {
                    "token1": "value=\"",
                    "token2": "\"",
                    "replace": [
                        {
                            "prefix": "%%url%%?episode="
                        },
                        {
                            "match": "\\?translations=false",
                            "text": ""
                        }
                    ]
                },
                "title": {
                    "token1": ">",
                    "token2": "</",
                    "replace": [
                        {
                            "match": "(Серия) (\\d+)(.*)",
                            "text": "Серия $2"
                        },
                        {
                            "match": "(\\d+) серия(.*)",
                            "text": "Серия $1"
                        }
                    ]
                },
                "uniq": {
                    "token1": ">",
                    "token2": "</"
                },
                "end": "</select>"
            }
        ]
    },
