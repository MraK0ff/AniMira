    "manga_list_complete": {
        "iterator": [
            {
                "category": {
                    "tag": "main",
                    "name": "Latest"
                },
                "base_url": "$scheme$//$hostname$/manga-list/latest-manga?page=",
                "append_nums": {
                    "from": 1,
                    "to": 2300,
                    "step": 1
                }
            }
        ],
        "add_manga": {
            "next": "list-comic-item-wrap",
            "link": {
                "token1": "href=\"",
                "token2": "\""
            },
            "cover": {
                "token1": "src=\"",
                "token2": "\""
            },
            "title": {
                "token1": "title=\"",
                "token2": "\""
            }
        }
    },
    "manga_complete": {
        "title": {
            "token1": "<h1>",
            "token2": "</"
        },
        "cover": {
            "skip": "og:image",
            "token1": "content=\"",
            "token2": "\""
        },
        "author": {
            "skip": "Author(s)",
            "token1": "p>",
            "token2": "<"
        },
        "summary": {
            "skip": " summary:",
            "token1": "</p>",
            "token2": "</div>"
        },
        "status": {
            "complete": "Completed</li>",
            "ongoing": "Ongoing</li>"
        },
        "is_mature": {
            "start": "\"genres\"",
            "end": "</li>",
            "values": [
                "16",
                "Ecchi",
                "Horror"
            ]
        },
        "is_adult": {
            "start": "\"genres\"",
            "end": "</li>",
            "values": [
                "18",
                "Adult"
            ]
        },
        "add_genres": {
            "start": "\"genres\"",
            "token1": "\">",
            "token2": "</",
            "end": "</li>"
        },
        "content_type": {
            "default": "manga"
        },
        "chapters_from_page": {
            "skip": "<meta property=\"og:url\"",
            "token1": "content=\"",
            "token2": "\"",
            "replace": [
                {
                    "match": "/manga/",
                    "text": "/api/manga/"
                },
                {
                    "sufix": "/chapters?limit=-1"
                }
            ]
        },
        "add_chapter": {
            "start": "\"data\":",
            "next": "\"chapter_name\":",
            "link": {
                "token1": "\"chapter_slug\":\"",
                "token2": "\"",
                "replace": [
                    {
                        "prefix": "%%url%%"
                    },
                    {
                        "match": "/api/manga/",
                        "text": "/manga/"
                    },
                    {
                        "match": "chapters\\?limit=-1",
                        "text": ""
                    }
                ]
            },
            "title": {
                "token1": "\"chapter_name\":\"",
                "token2": "\"",
                "replace": {
                    "match": "&nbsp;",
                    "text": ""
                }
            },
            "end": "}]"
        }
    },
    "chapter_complete": {
        "add_images": {
            "start": "class=\"container-chapter-reader",
            "token1": " src='http",
            "token2": "'",
            "end": "<div class",
            "replace": {
