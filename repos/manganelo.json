    "test": [
        {
            "proc": "manga_list_complete",
            "testpages": "3",
            "assert": {
                "mangas": [
                    {
                        "title": "@^(\\w+)",
                        "link": "@https://www.natomanga.com/",
                        "uniq": "@^(\\w+)"
                    }
                ],
                "mangas_count": ">=48"
            }
        },
        {
            "proc": "manga_complete",
            "link": "https://www.natomanga.com/manga/bleach",
            "assert": {
                "title": "Bleach",
                "author": "Tite Kubo",
                "cover": "https://img-r1.2xstorage.com/thumb/bleach.webp",
                "summary": "@Despite always",
                "genres": "@action",
                "status": "complete",
                "genres_count": ">=7",
                "chapters_count": ">=600",
                "chapters": [
                    {
                        "title": "Chapter 0",
                        "link": "https://www.natomanga.com/manga/bleach/chapter-0",
                        "folder": "chapter-0/"
                    },
                    {
                        "title": "Chapter 2",
                        "link": "https://www.natomanga.com/manga/bleach/chapter-2"
                    }
                ]
            }
        },
        {
            "proc": "chapter_complete",
            "link": "https://www.natomanga.com/manga/bleach/chapter-2",
            "assert": {
                "pages": [
                    {
                        "image": "@https://imgs-\\d+.2xstorage\\.com/.*/\\d+/0.webp"
                    },
                    {
                        "image": "@https://imgs-\\d+.2xstorage\\.com/.*/\\d+/1.webp"
                    },
                    {
                        "image": "@https://imgs-\\d+.2xstorage\\.com/.*/\\d+/2.webp"
