    "manga_complete": {
        "title": {
            "after": "<h1 itemprop=\"name\"",
            "token1": "\">",
            "token2": "</",
            "replace": [
                {
                    "match": "\\[All Chapters\\]",
                    "text": ""
                },
                {
                    "trim": true
                }
            ]
        },
        "alt_title": {
            "skip": "alternative-title",
            "token1": "\">",
            "token2": "</"
        },
        "cover": {
            "after": "property=\"og:image\"",
            "token1": "content=\"",
            "token2": "\""
        },
        "author": {
            "token1": "<span itemprop=\"author\">",
            "token2": "</"
        },
        "summary": {
            "after": "<p class=\"description",
            "token1": ">",
            "token2": "</p>",
            "replace": {
                "match": "<.*?>",
                "text": ""
            }
        },
        "status": {
            "complete": "<strong class=\"completed\">",
            "ongoing": "<strong class=\"ongoing\">"
        },
        "add_genre": {
            "after": "/?genre=",
            "token1": "\">",
            "token2": "</"
        },
        "add_tag": {
            "after": "/?tag=",
            "token1": "\">",
            "token2": "</"
        },
        "add_chapter": {
            "next": "<li data-chapterno",
            "link": {
                "token1": "href=\"",
                "token2": "\"",
                "replace": [
                    {
                        "match": "www.mcreader.net",
                        "text": "honey-manga.com.ua"
                    },
                    {
                        "match": "https://www.readmcreader.com/manga/read\\?comic=",
                        "text": ""
                    },
                    {
                        "match": "www.novel-fast.club",
                        "text": "honey-manga.com.ua"
                    }
                ]
            },
            "title": {
                "skip": "href=\"",
                "token1": "class=\"chapter-title\">",
                "token2": "</"
            },
            "uniq": {
                "skip": "href=\"",
                "token1": "class=\"chapter-title\">",
                "token2": "</"
            }
        }
    },
    "chapter_complete": {
        "add_images": {
            "start": "id=\"chapter-reader",
            "token1": "<img src=\"",
            "token2": "\"",
            "end": "<div style"
        }
    },
    "test": [
        {
            "proc": "manga_search_complete",
            "query": "sword",
            "assert": {
                "mangas": [
                    {
                        "title": "@^(\\p{L}+)",
                        "link": "@https://honey-manga.com.ua/",
                        "uniq": "@^(\\w+)"
                    }
                ],
                "mangas_count": ">=5"
            }
        },
        {
            "proc": "manga_list_complete",
            "assert": {
                "mangas": [
                    {
                        "title": "@^(\\p{L}+)",
                        "link": "@https://honey-manga.com.ua/",
                        "uniq": "@^(\\w+)"
                    }
                ],
                "mangas_count": ">=5"
            }
        },
        {
            "proc": "manga_complete",
            "link": "https://honey-manga.com.ua/manga/miracle-hero/",
            "assert": {
                "title": "Miracle Hero!",
                "alt_title": "미라클! 용사님",
                "author": "Jeongha",
                "cover": "https://honey-manga.com.ua/media/manga_covers/miracle-hero.jpg",
                "summary": "@^(Miracle Hero)",
                "genres": "@comedy",
                "status": "ongoing",
                "genres_count": ">=6",
                "chapters_count": ">=100",
                "chapters": [
                    {
                        "folder": "99-eng-li/",
                        "link": "https://honey-manga.com.ua/reader/en/miracle-hero-chapter-99-eng-li/",
                        "title": "99-eng-li"
                    }
                ]
            }
        },
        {
            "proc": "chapter_complete",
            "link": "https://honey-manga.com.ua/reader/en/miracle-hero-chapter-16-eng-li/",
            "assert": {
                "pages": [
                    {
                        "image": "https://www.toonix.xyz/cdn_mangaraw/miracle-hero/chapter-16/1.jpg"
                    }
                ],
                "pages_count": "31"
            }
        }
    ]
