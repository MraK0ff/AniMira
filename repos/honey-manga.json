    "manga_search_complete": {
        "search_link": "https://honey-manga.com.ua/search/?search=$query$",
        "query_type": "GET",
        "add_manga": {
            "start": "<ul class=\"novel-list grid col col2\">",
            "next": "class=\"novel-item\">",
            "link": {
                "token1": "href=\"",
                "token2": "\""
            },
            "title": {
                "token1": "title=\"",
                "token2": "\""
            },
            "cover": {
                "token1": "data-src='",
                "token2": "'"
            },
            "end": "</ul>"
        }
    },
    "manga_list_complete": {
        "iterator": [
            {
                "category": {
                    "tag": "main",
                    "name": "Latest"
                },
                "base_url": "https://honey-manga.com.ua/browse-comics/?rfilter=Updated&esults=1",
                "append_nums": {
                    "from": 0,
                    "to": 125,
                    "step": 1
                }
            }
        ],
        "add_manga": {
            "start": "<ul class=\"novel-list grid col col2\">",
            "next": "class=\"novel-item\">",
