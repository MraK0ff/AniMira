    "!seasons_complete": {
        "get_translations": true,
        "seasons_from_page": {
            "token1": "file:\"",
            "token2": "\""
        },
        "add_season": {
            "if": {
                "mode": "AND",
                "!contains": [
                    "folder"
                ],
                "then_values": {
                    "break": "true"
                },
                "default": {
                    "break": "true"
                }
            },
            "start": "[",
            "next": {
                "value_regexp": "\"title\":\"(.*?)\",\"folder\""
            },
            "link": "@null",
            "title": {
                "token1": "title\":\"",
                "token2": "\"",
                "replace": {
                    "match": "\\d+ серія",
                    "text": ""
                }
            },
            "end": "]}]"
        }
