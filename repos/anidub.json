    "authorization_complete": {
        "zlogo": "http://images.mangawatcherx.com/parser/logo/anime/anidub_logo.png",
        "registration": "$scheme$//$hostname$/index.php?do=register",
        "webview_auth_supported": true,
        "disable_classic_auth": true,
        "expires": 31449600000,
        "values": {
            "login": "submit",
            "login_name": {
                "label": "Login",
                "hint": "Логин",
                "kind": "text"
            },
            "login_password": {
                "label": "Password",
                "hint": "Пароль",
                "kind": "password"
            }
        },
        "request": {
            "method": "post",
            "url": "$scheme$//$hostname$/"
        },
        "response_check": {
            "cookies": {
                "dle_user_id": "@\\d+"
            },
            "headers": {
                "Set-Cookie": "@dle_user_id=\\d+"
            }
        }
    },
    "anime_search_complete": {
        "search_link": "$scheme$//$hostname$/index.php?do=search&subaction=search&search_start=$page$&full_search=0&result_from=1&story=$query$",
        "query_type": "GET",
        "add_anime": {
            "next": "class=\"th-item\"",
            "link": {
                "token1": "href=\"",
                "token2": "\""
            },
            "additional_title": {
                "skip": "th-title",
                "token1": ">",
                "token2": "<",
                "replace": [
                    {
                        "match": "\\[.*\\]",
                        "text": ""
                    },
                    {
                        "match": "\" alt=.*",
                        "text": ""
                    }
                ]
            },
            "title": {
                "skip": "th-subtitle",
                "token1": "<span>",
                "token2": "</",
                "replace": [
                    {
                        "match": "\\[.*\\]",
                        "text": ""
                    },
                    {
                        "trim": true
                    }
                ]
            },
            "!uniq": {
                "skip": "th-title",
                "token1": ">",
                "token2": "<"
            },
            "cover": {
                "skip": "data-src=",
                "token1": "\"",
                "token2": "\"",
                "replace": [
                    {
                        "match": "&#58;",
                        "text": ":"
                    },
                    {
                        "match": "^/uploads",
                        "text": "$scheme$//$hostname$/uploads"
                    }
                ]
            },
            "season": {
                "after": "th-rating",
                "token1": ">",
                "token2": "<",
                "prefix": "★"
            },
            "episodes_aired": {
                "after": "th-title",
                "before": "th-subtitle",
                "token1": "[",
                "token2": "]"
            },
            "add_genres": {
                "start": ">Жанр:<",
                "next": "a href",
                "token1": "\">",
                "token2": "<",
                "end": "</li>"
            },
            "skip_anime": {
                "link_contains": [
                    "/anidub_news/",
                    "/videoblog/"
                ]
            }
        }
    },
