        "add_manga": {
            "start": "\"tiles",
            "next": "class=\"img\"",
            "link": {
                "after": "<h3>",
                "token1": "href=\"",
                "token2": "\""
            },
            "title": {
                "after": "img class",
                "token1": "title='",
                "token2": "' a",
                "replace": {
                    "match": ".*\\((.*)\\)$",
                    "text": "$1"
                }
            },
            "additional_title": {
                "after": "img class",
                "token1": "title='",
                "token2": "' a",
                "replace": {
                    "match": " \\(.*\\)$",
                    "text": ""
                }
            },
            "cover": {
                "token1": "data-original='",
                "token2": "'",
                "replace": {
                    "match": "_p.",
                    "text": "."
                }
            },
            "end": "class=\"rightContent"
        }
    },
