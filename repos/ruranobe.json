    "!manga_search_complete": {
        "search_link": "https://api.novel.tl/api/site/v2/graphql",
        "query_type": "POST",
        "headers": {
            "Accept": "application/json",
            "Content-Type": "application/json; charset=UTF-8"
        },
        "body_data": "{\"operationName\": \"MiniSearch\", \"variables\": {\"term\": \"$query$\", \"hostname\": \"ruranobe.ru\"}, \"query\": \"query MiniSearch($hostname: String!, $term: String!) {search(currentSection: {fullUrl: $hostname}, filter: {query: $term}, page: {pageSize: 5, pageNumber: 1}) {projects {content {title url covers{fileId url} } } } }\"}",
        "add_manga": {
            "start": "content",
            "next": "\"tit",
            "title": {
                "skip": "le\"",
                "token1": "\"",
                "token2": "\""
            },
            "uniq": {
                "token1": "/r/",
                "token2": "\""
            },
            "link": {
                "skip": "\"url\"",
                "token1": "\"",
                "token2": "\"",
                "replace": [
                    {
                        "prefix": "https:"
                    },
                    {
                        "match": "(https:)(\\w+)",
                        "text": "$1//ruranobe.ru/r/$2"
                    }
                ]
            },
            "cover": {
                "skip": "covers",
                "token1": "images",
                "token2": "\"",
                "replace": {
                    "prefix": "https://ruranobe.ru/images"
                }
            }
        }
    },
    "manga_list_complete": {
        "iterator": [
            {
                "category": {
                    "tag": "main",
                    "name": "Последние"
                },
                "base_url": "$scheme$//$hostname$/projects;page=",
                "append_nums": {
                    "from": 1,
                    "to": 5,
                    "step": 1
                }
            }
        ],
        "add_manga": {
            "start": ">Проекты</span",
            "next": "class=\"project-card\"",
            "link": {
                "after": "project-card__link",
                "token1": "href=\"",
                "token2": "\"",
                "replace": {
                    "prefix": "$scheme$//$hostname$"
                }
            },
            "title": {
                "token1": "class=\"project-card__title\" title=\"",
                "token2": "\""
            },
            "cover": {
                "after": "<img",
                "before": " alt=",
                "token1": "src=\"",
                "token2": "\"",
                "replace": {
                    "prefix": "$scheme$//$hostname$"
                }
            },
            "end": "Правообладателям<"
        }
    },
