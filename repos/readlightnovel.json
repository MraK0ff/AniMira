{
    "id": 70301,
    "version": 10,
    "title": "Read Light Novel",
    "host": "https://www.readlightnovel.meme/hub141222",
    "public_link": "https://www.readlightnovel.meme",
    "hash_tag": "readlightnovel",
    "folder": "readlightnovel",
    "name": "readlightnovel",
    "language": "en",
    "content_type": "light_novel",
    "chapters_order": true,
    "deleted": true,
    "deleted_message": "Site is dead",
    "user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/96.0.4664.110 Safari/537.36",
    "icon_link": "http://images.mangawatcherx.com/parser/icon/light_novel/readlightnovel.png",
    "self_link": "https://api.anilabx.xyz/v3/parser/get?type=light_novel&parser=readlightnovel",
    "author": {
        "name": "AniLabX Team",
        "email": "anilabx.supp@gmail.com"
    },
    "manga_search_complete": {
        "search_link": "https://www.readlightnovel.meme/search/autocomplete",
        "query_type": "POST",
        "headers": {
            "X-Requested-With": "XMLHttpRequest"
        },
        "form_data": {
            "q": "$query$"
        },
        "add_manga": {
            "next": "<li>",
            "title": {
                "token1": "class=\"title\">",
                "token2": "<"
            },
            "link": {
                "token1": "href=\"",
                "token2": "\""
            },
            "cover": {
                "token1": "img src=\"",
                "token2": "\""
            }
        }
    },
    "manga_list_complete": {
        "iterator": [
            {
                "base_url": "https://www.readlightnovel.meme/novel-list/",
                "append_array": [
                    "",
                    "a",
                    "b",
                    "c",
                    "d",
                    "e",
                    "f",
                    "g",
                    "h",
                    "i",
                    "j",
                    "k",
                    "l",
                    "m",
                    "n",
                    "o",
                    "p",
                    "q",
                    "r",
                    "s",
                    "t",
                    "u",
                    "v",
                    "w",
                    "x",
                    "y",
                    "z"
                ]
            }
        ],
        "add_manga": {
            "start": "list-by-word-body",
            "next": "<li>",
            "title": {
                "skip": "pop-header",
                "token1": "\">",
                "token2": "<",
                "replace": {
                    "trim": true
                }
            },
            "link": {
                "token1": "href=\"",
                "token2": "\""
            },
            "cover": {
                "token1": "img src=\"",
                "token2": "\""
            }
        }
    },
    "manga_complete": {
        "title": {
            "token1": "<h1>",
            "token2": "<"
        },
        "alt_title": {
            "skip": ">Alternative Names<",
            "token1": "<li>",
            "token2": "</ul>",
            "replace": {
                "match": "</a></li>\n                                                                                                            ",
                "text": ", "
            }
        },
        "author": {
            "skip": "Author(s)",
            "token1": "<li>",
            "token2": "</li>"
        },
        "summary": {
            "skip": ">Description<",
            "after": "><p",
            "token1": ">",
            "token2": "</p></div>",
            "replace": {
                "match": "</?[p]+[^>]*>",
                "text": ""
            }
        },
        "production_year": {
            "skip": ">Year<",
            "token1": "<li>",
            "token2": "</li>"
        },
        "status": {
            "single": ">Single<",
            "complete": ">Completed<",
            "ongoing": ">Ongoing<",
            "empty": ">No Chapters Yet<"
        },
        "translation_status": {
            "complete": ">Completed<",
            "ongoing": ">Ongoing<"
        },
        "cover": {
            "after": "og:image",
            "token1": "content=\"",
            "token2": "\""
        },
        "add_genres": {
            "start": ">Genre<",
            "end": "</ul>",
            "after": "href=\"https://www.readlightnovel.meme/category",
            "token1": ">",
            "token2": "<"
        },
        "content_type": {
            "default": "light_novel"
        },
        "add_chapter": {
            "start": "chapter-chs",
            "end": "block-header",
            "next": "<li>",
            "link": {
                "token1": "href=\"",
                "token2": "\""
            },
            "title": {
                "skip": "href=\"",
                "token1": ">",
                "token2": "<"
            }
        }
    },
    "chapter_complete": {
        "add_text": {
            "after": "<div class=\"hidden\" id=\"growfoodsmart\">",
            "token1": "<div class=\"hidden\" id=\"growfoodsmart\">",
            "token2": "<div class=\"row\">"
        }
    },
    "test": [
        {
            "proc": "manga_search_complete",
            "query": "Tensei Shitara Slime",
            "assert": {
                "mangas": [
                    {
                        "title": "Tensei Shitara Slime Datta Ken (WN)",
                        "link": "https://www.readlightnovel.meme/tensei-shitara-slime-datta-ken-wn",
                        "cover": "https://www.readlightnovel.meme/uploads/posters/tensei-shitara-slime-datta-ken-wn.jpg"
                    }
                ],
                "mangas_count": ">=2"
            }
        },
        {
            "proc": "manga_list_complete",
            "testpages": "3",
            "assert": {
                "mangas": [
                    {
                        "title": "@^(\\p{L}+)",
                        "link": "@https://www.readlightnovel.meme/",
                        "uniq": "@^(\\p{L}+)"
                    }
                ],
                "mangas_count": ">=60"
            }
        },
        {
            "proc": "manga_complete",
            "link": "https://www.readlightnovel.meme/martial-god-asura-120822",
            "assert": {
                "title": "Martial God Asura",
                "alt_title": "Tu La Vũ Thần, Xiuluo Wushen, 修罗武神, 修羅武神,",
                "author": "Kindhearted Bee",
                "cover": "https://www.readlightnovel.meme/uploads/posters/martial-god-asura.jpg",
                "genres": "[action, adventure, ecchi, fantasy, harem, martialarts, adult, romance, seinen, supernatural]",
                "status": "ongoing",
                "genres_count": ">=10",
                "chapters_count": ">=3602",
                "chapters": [
                    {
                        "link": "https://www.readlightnovel.meme/martial-god-asura-120822/chapter-3595",
                        "title": "CH 3595"
                    },
                    {
                        "link": "https://www.readlightnovel.meme/martial-god-asura-120822/chapter-3594",
                        "title": "CH 3594"
                    }
                ]
            }
        },
        {
            "proc": "chapter_complete",
            "link": "https://www.readlightnovel.meme/martial-god-asura-120822/chapter-3595",
            "title": "CH 3595",
            "assert": {
                "pages": [
                    {
                        "text": "@^(<br>)"
                    }
                ],
                "pages_count": "1"
            }
        }
    ]
}